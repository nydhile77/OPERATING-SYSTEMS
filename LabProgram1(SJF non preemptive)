#include <stdio.h>

int main() {
    int n, at[10], bt[10], ct[10], tat[10], wt[10], done[10];
    int i, time = 0, completed = 0, min, index;
    float avg_tat = 0, avg_wt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Enter AT and BT for P%d: ", i+1);
        scanf("%d %d", &at[i], &bt[i]);
        done[i] = 0;
    }

    while(completed < n) {
        min = 999;
        index = -1;

        for(i = 0; i < n; i++) {
            if(at[i] <= time && done[i] == 0 && bt[i] < min) {
                min = bt[i];
                index = i;
            }
        }

        if(index == -1) {
            time++;
        } else {
            ct[index] = time + bt[index];
            tat[index] = ct[index] - at[index];
            wt[index] = tat[index] - bt[index];

            time = ct[index];
            done[index] = 1;
            completed++;

            avg_tat += tat[index];
            avg_wt += wt[index];
        }
    }

    printf("\nP\tAT\tBT\tCT\tTAT\tWT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", i+1, at[i], bt[i], ct[i], tat[i], wt[i]);
    }

    printf("\nAverage TAT = %.2f", avg_tat/n);
    printf("\nAverage WT = %.2f\n", avg_wt/n);
    printf("nydhile nagaraj 1WA24CS195");

    return 0;
}  
